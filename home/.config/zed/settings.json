// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
  },
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4-mini",
        "enable_thinking": false
      }
    ],
    "play_sound_when_agent_done": true,
    "default_profile": "write",
    "model_parameters": [],
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
  },
  "ui_font_size": 16,
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_size": 13,
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "use_system_window_tabs": true,
  "minimap": {
    "show": "auto",
    "thumb": "hover",
    // "display_in": "active_editor"
  },
  "autosave": "on_focus_change",
  "project_panel": { "default_width": 360 },
  "outline_panel": { "default_width": 360 },
  "collaboration_panel": { "button": false },
  "terminal": {
    "font_family": "Monaspace Argon",
    "shell": {
      "program": "fish",
    },
    "detect_venv": "off",
  },
  "file_types": {
    "JSONC": [
      "**/.zed/**/*.json",
      "**/zed/**/*.json",
      "**/Zed/**/*.json",
      "**/.vscode/**/*.json",
    ],
    "Shell Script": [".env.*", ".envrc"],
  },
  "languages": {
    "Markdown": {
      "soft_wrap": "preferred_line_length",
    },
    "Python": {
      "wrap_guides": [88],
      "language_servers": [
        "ty",
        "ruff",
        "!basedpyright",
        "!pyrefly",
        "!pyright",
        "!pylsp",
      ],
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.fixAll.ruff" },
        { "code_action": "source.organizeImports.ruff" },
        { "language_server": { "name": "ruff" } },
      ],
    },
  },
}
